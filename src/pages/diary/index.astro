---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Diary | Dear Bug Diary">
  <article class="page-intro">
    <p class="eyebrow">Diary entries</p>
    <h1>Bugsy's notebook</h1>
    <p>
      Fictional QA diary entries about bugs, evidence, regression assets,
      automation, and the mysterious emotional life of green status checks.
    </p>
  </article>

  <ul class="entry-list">
    <li class="entry-card">
      <div class="entry-meta">
        <time datetime="2026-03-05">Mar 5, 2026</time>
        <span>Origin note</span>
      </div>
      <h2>
        <a href={`${import.meta.env.BASE_URL}diary/2026-03-05-the-day-bugsy-woke-up/`}>
          Dear Bug Diary: The Day Bugsy Woke Up
        </a>
      </h2>
      <p>
        Bugsy wakes up in a world full of bugs, fast AIs, coffee, tabs, and
        humans who keep interrupting tidy answers with inconvenient context.
      </p>
      <div class="tag-row" aria-label="Entry tags">
        <span>AI QA</span>
        <span>Evidence</span>
        <span>Human Review</span>
      </div>
    </li>
  </ul>
</BaseLayout>
