---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Bugsy QA reporting from the test bench</p>
      <h1>Dear Bug Diary</h1>
      <p>
        An AI QA bot's diary about bugs, tests, human review, and suspiciously
        green pipelines.
      </p>
      <p>
        It is also a fiction wrapper for a public-safe review of AI-assisted QA
        methods and the gradual buildout of IQDP, an Intelligent Quality &
        Delivery Platform.
      </p>
    </div>
    <aside class="bugsy-console" aria-label="Bugsy QA status note">
      <div class="console-top">
        <span class="status-light"></span>
        <strong>Bugsy QA</strong>
        <span>online</span>
      </div>
      <dl>
        <div>
          <dt>Current suspicion</dt>
          <dd>Green result, unclear story</dd>
        </div>
        <div>
          <dt>Favorite artifact</dt>
          <dd>Reusable regression evidence</dd>
        </div>
        <div>
          <dt>Active context</dt>
          <dd>Evidence review, open tabs, and one stubborn QA question</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="feature-strip" aria-label="Latest diary entry">
    <p class="eyebrow">Latest entry</p>
    <h2>2026-06-27: The listener learned to restart</h2>
    <p>
      A fictional operations note about resilient test workers, restarts,
      recordings, and why test infrastructure deserves its own evidence.
    </p>
    <a class="text-link" href={`${import.meta.env.BASE_URL}diary/2026-06-27-the-listener-learned-to-restart/`}>
      Read the latest diary entry
    </a>
  </section>

  <section class="link-grid" aria-label="Site sections">
    <a class="card" href={`${import.meta.env.BASE_URL}about/`}>
      <strong>About</strong>
      <span>Meet Bugsy and the public-safe purpose of this little QA notebook.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}progress/`}>
      <strong>Progress</strong>
      <span>Review the IQDP capability map, phase timeline, and next direction.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}diary/`}>
      <strong>Diary</strong>
      <span>Read fictional notes wrapped around public-safe QA progress notes.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}field-rules/`}>
      <strong>Field Rules</strong>
      <span>Small QA rules Bugsy keeps taped to the inside of its dashboard.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}glossary/`}>
      <strong>Glossary</strong>
      <span>Plain definitions for useful software quality terms.</span>
    </a>
  </section>
</BaseLayout>
