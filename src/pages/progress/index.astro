---
import BaseLayout from '../../layouts/BaseLayout.astro';

const capabilities = [
  {
    title: 'Requirements governance',
    body:
      'Stable requirement identity, metadata, traceability rules, and structured import patterns for turning planning input into reviewable QA material.',
  },
  {
    title: 'Test generation and review',
    body:
      'AI-assisted test drafting, validation, review artifacts, and export-ready packages that keep generated work inspectable before it is trusted.',
  },
  {
    title: 'Test asset management',
    body:
      'Durable reviewed case assets, mapping records, manifest links, and feedback indexes that separate source assets from runtime evidence.',
  },
  {
    title: 'Execution feedback loops',
    body:
      'Contract, API, UI, and generated-test loops that return structured feedback from execution back into the generation and review process.',
  },
  {
    title: 'Desktop evidence architecture',
    body:
      'Machine-role boundaries, headed execution evidence, screenshots, recordings, and logs tied to the environment that observed behavior.',
  },
  {
    title: 'Metrics and reporting',
    body:
      'Daily, historical, developer, QA, and workbook-style reporting flows that make quality and delivery signals easier to inspect over time.',
  },
  {
    title: 'Knowledge governance',
    body:
      'A separation between private notes, draft lessons, review proposals, and shared guidance so fast learning can become trusted practice.',
  },
  {
    title: 'AI workflow standardization',
    body:
      'Reusable assistant workflows for test management, execution, bug drafting, knowledge capture, reporting, and live run learning.',
  },
];

const phases = [
  {
    month: 'March',
    title: 'Evidence and review foundations',
    body:
      'The exploration started with a simple rule: fast AI output needs evidence, review gates, traceability, and generated test asset discipline before it becomes QA work.',
  },
  {
    month: 'April',
    title: 'Reporting and measurable outputs',
    body:
      'The work expanded from individual artifacts into reporting validation, digest structure, metrics review, and delivery hygiene so outputs could be checked and reused.',
  },
  {
    month: 'May',
    title: 'Reusable automation and shared guidance',
    body:
      'The focus moved toward batch reporting, reusable automation patterns, and shared operating rules that could travel beyond a single workflow.',
  },
  {
    month: 'June',
    title: 'Knowledge governance, evidence architecture, and resilience',
    body:
      'The later phase connected regression learning, knowledge boundaries, desktop evidence architecture, and operational resilience for the automation system itself.',
  },
];

const maturity = [
  {
    capability: 'Evidence-first workflow',
    status: 'Built',
    proof:
      'Generated work is treated as draft material until it has source context, review notes, evidence, and repeatable checks.',
    next: 'Make evidence links easier to follow across requirement, test, and report artifacts.',
  },
  {
    capability: 'AI-generated test review gate',
    status: 'Built',
    proof:
      'AI can draft and organize test material, but the method keeps a human review boundary before reuse.',
    next: 'Tighten the checklist for generated assets that are promoted into long-lived test suites.',
  },
  {
    capability: 'Reporting validation',
    status: 'Built',
    proof:
      'Reports are handled as inspectable outputs with definitions, filters, denominators, and reviewable exceptions.',
    next: 'Connect reporting signals more directly to execution feedback and requirement coverage.',
  },
  {
    capability: 'Knowledge governance',
    status: 'In progress',
    proof:
      'Private notes, draft lessons, review proposals, and shared guidance are kept in separate lanes.',
    next: 'Improve promotion rules so useful learning becomes team-safe guidance without losing context.',
  },
  {
    capability: 'Requirement-test-execution traceability',
    status: 'In progress',
    proof:
      'Identity, mapping, generated assets, execution results, and reports are being shaped into one connected chain.',
    next: 'Formalize linking across the full path from requirement intake to reusable regression evidence.',
  },
  {
    capability: 'Governed AI repair',
    status: 'Next',
    proof:
      'Repair is not treated as magic. It needs failure evidence, proposed change boundaries, rerun proof, and review.',
    next: 'Define when AI may suggest fixes, how those fixes are reviewed, and what evidence closes the loop.',
  },
];

const operatingPrinciples = [
  'AI output is fast draft work until evidence makes it reusable.',
  'A green result is a signal, not a story.',
  'Reports need definitions, filters, denominators, and exceptions.',
  'Private learning can inform public writing only after it is generalized.',
  'Useful QA automation includes recovery, ownership, and proof of what actually ran.',
];
---

<BaseLayout
  title="Progress | Bugsy"
  description="A public-safe progress review of IQDP, an AI-assisted QA operating model."
>
  <article class="page-intro">
    <p class="eyebrow">Progress review</p>
    <h1>Building IQDP: An AI-Assisted QA Operating Model</h1>
    <p>
      A public-safe progress review of how AI can connect requirements, testing,
      evidence, reporting, knowledge, and governance.
    </p>
  </article>

  <section class="feature-strip">
    <p class="eyebrow">Why this matters</p>
    <h2>Quality work needs a connected operating model.</h2>
    <p>
      The problem is not only test automation. A stronger QA practice needs a
      traceable path from requirements to tests, from execution to evidence,
      from evidence to reporting, and from lessons learned to governed reuse.
      IQDP, Intelligent Quality & Delivery Platform, is the target system for
      that exploration.
    </p>
  </section>

  <section>
    <p class="eyebrow">What IQDP means</p>
    <h2>Traceable, measurable, reusable, and governed AI-assisted QA.</h2>
    <p>
      IQDP is a methodology and platform direction for using AI as an assistant
      in QA work while preserving human review, evidence discipline, and
      reusable operating rules. The underlying repo review is source material
      only; the public record is expressed as capabilities, methods, and
      progress.
    </p>
  </section>

  <section>
    <p class="eyebrow">Capability map</p>
    <h2>Eight connected capabilities, not eight isolated tools.</h2>
    <p>
      The work is organized around QA capabilities rather than implementation
      inventory. Each area is useful alone, but the real value appears when
      requirements, tests, execution, evidence, reports, and knowledge can
      reinforce each other.
    </p>
    <ul class="entry-list">
      {
        capabilities.map((item) => (
          <li class="entry-card">
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <p class="eyebrow">Maturity board</p>
    <h2>What is built, what is still forming, and what comes next.</h2>
    <p>
      This board is intentionally method-focused. It shows current progress in
      public-safe language without turning private implementation details into
      a public inventory.
    </p>
    <div class="maturity-board">
      {
        maturity.map((item) => (
          <article class="maturity-card">
            <div class="entry-meta">
              <span>{item.status}</span>
            </div>
            <h3>{item.capability}</h3>
            <p>{item.proof}</p>
            <p><strong>Next:</strong> {item.next}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <p class="eyebrow">Phase timeline</p>
    <ul class="entry-list">
      {
        phases.map((phase) => (
          <li class="entry-card">
            <div class="entry-meta">
              <span>{phase.month}</span>
            </div>
            <h2>{phase.title}</h2>
            <p>{phase.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <p class="eyebrow">Current maturity</p>
    <div class="link-grid">
      <div class="card">
        <strong>Built</strong>
        <span>
          Evidence-first workflows, review gates for AI-generated output,
          generated test asset discipline, reporting foundations, and knowledge
          governance boundaries.
        </span>
      </div>
      <div class="card">
        <strong>In progress</strong>
        <span>
          Stronger traceability across requirements, tests, execution, and
          reporting; tighter feedback loops between generation and execution;
          resilient automation operations.
        </span>
      </div>
      <div class="card">
        <strong>Next</strong>
        <span>
          Governed AI repair, formal test-management linking, multi-project
          onboarding, and broader IQDP operating model stabilization.
        </span>
      </div>
    </div>
  </section>

  <section class="feature-strip">
    <p class="eyebrow">Operating principles</p>
    <h2>The method is becoming a set of reusable QA rules.</h2>
    <ul class="compact-list">
      {operatingPrinciples.map((principle) => <li>{principle}</li>)}
    </ul>
  </section>
</BaseLayout>
